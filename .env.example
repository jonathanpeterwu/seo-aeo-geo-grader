# ── App ────────────────────────────────────────────────────
# Required for Stripe success/cancel redirects in production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Stripe ─────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Leave blank for dev mode (instant upgrades, no payment)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret from: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products + prices in Stripe Dashboard, paste IDs here:
#   Site Pass: one-time $99 payment
#   Pro: $49/month recurring
#   Agency: $149/month recurring
STRIPE_PRICE_SITE_PASS=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Email (optional) ──────────────────────────────────────
# All grading + PDF download works without email configured.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=grader@yourdomain.com
