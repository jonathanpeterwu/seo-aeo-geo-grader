# SMTP Configuration for email reports (optional)
# Email delivery is optional — all grading + PDF download works without it.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=grader@yourdomain.com

